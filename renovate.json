{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":enableDependencyDashboard"
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "groupName": "docker-images",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateType": "patch",
      "groupName": "docker-patch-updates",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateType": "minor",
      "groupName": "docker-minor-updates",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateType": "major",
      "groupName": "docker-major-updates",
      "automerge": false
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["*/traefik", "*/prometheus/*", "*/grafana/*", "*/loki/*", "*/tempo/*", "*/otel/*", "*/alertmanager/*", "*/node-exporter/*", "*/cadvisor/*", "*/promtail/*"],
      "groupName": "docker-security-critical",
      "automerge": true,
      "automergeType": "pr",
      "schedule": ["before 4am"]
    },
    {
      "matchDatasources": ["helm"],
      "groupName": "helm-charts",
      "automerge": false
    },
    {
      "matchDatasources": ["helm"],
      "matchUpdateType": "patch",
      "groupName": "helm-patch-updates",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchDatasources": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "schedule": ["before 4am on monday"],
  "timezone": "Australia/Melbourne",
  "prHourlyLimit": 5,
  "labels": ["dependencies", "renovate"],
  "assignees": ["IamVanshKhanna"],
  "reviewers": ["IamVanshKhanna"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dependency Dashboard",
  "visibility": "private"
}