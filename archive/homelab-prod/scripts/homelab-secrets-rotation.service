[Unit]
Description=Homelab Secrets Rotation
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=vansh
Environment=HOME=/home/vansh
WorkingDirectory=/home/vansh/homelab-prod
ExecStart=/home/vansh/homelab-prod/scripts/secrets-rotation.sh
EnvironmentFile=/home/vansh/homelab-prod/.env

[Install]
WantedBy=multi-user.target