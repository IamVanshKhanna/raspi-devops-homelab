# WireGuard Server Config - TEMPLATE ONLY
# Real config is auto-generated by linuxserver/wireguard container
# DO NOT commit your real wg0.conf - it contains private keys
# Real config lives inside the wireguard Docker volume at /config/wg0.conf

[Interface]
Address = 10.13.13.1/24
ListenPort = 51820
PrivateKey = SERVER_PRIVATE_KEY_GOES_HERE
PostUp = iptables -A FORWARD -i wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE

# Peer 1 - Phone
[Peer]
PublicKey = PEER1_PUBLIC_KEY_GOES_HERE
AllowedIPs = 10.13.13.2/32
PersistentKeepalive = 25

# Peer 2 - Laptop
[Peer]
PublicKey = PEER2_PUBLIC_KEY_GOES_HERE
AllowedIPs = 10.13.13.3/32
PersistentKeepalive = 25

# Peer 3 - Work Machine
[Peer]
PublicKey = PEER3_PUBLIC_KEY_GOES_HERE
AllowedIPs = 10.13.13.4/32
PersistentKeepalive = 25

# To retrieve auto-generated peer configs:
# docker exec wireguard cat /config/peer1/peer1.conf
# Or scan QR code on phone:
# docker exec wireguard bash -c 'qrencode -t ansiutf8 < /config/peer1/peer1.conf'
