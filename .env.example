# =============================================================
# homelab-prod - Environment Variables
# Copy this file: cp .env.example .env
# Then fill in every value before deploying.
# NEVER commit your .env file - it is in .gitignore
# =============================================================

# --- GENERAL --------------------------------------------------
TZ=Australia/Melbourne
PUID=1000
PGID=1000
DATA_DIR=/mnt/data
BACKUP_DIR=/mnt/backup

# --- DOMAIN ---------------------------------------------------
# Your domain or free DuckDNS subdomain
# e.g. myhomelab.duckdns.org
DOMAIN=yourdomain.com
ACME_EMAIL=your@email.com

# --- TRAEFIK --------------------------------------------------
TRAEFIK_DASHBOARD_USER=admin
# Generate hashed password with:
# echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_PASS=$$2y$$05$$replacethiswithyourhashedpassword

# --- NEXTCLOUD ------------------------------------------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me_strong_password
NEXTCLOUD_TRUSTED_DOMAINS=cloud.yourdomain.com

# --- MARIADB (Nextcloud database) -----------------------------
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=change_me_db_password

# --- VAULTWARDEN ----------------------------------------------
# Generate token with: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=change_me_random_64char_token_here

# --- GRAFANA --------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana_password
GF_SERVER_ROOT_URL=https://grafana.yourdomain.com

# --- PIHOLE ---------------------------------------------------
PIHOLE_WEBPASSWORD=change_me_pihole_password
PIHOLE_DNS1=1.1.1.1
PIHOLE_DNS2=8.8.8.8

# --- WIREGUARD ------------------------------------------------
WG_HOST=yourdomain.com
WG_DEFAULT_DNS=192.168.1.50
WG_ALLOWED_IPS=0.0.0.0/0
WG_PEERS=3

# --- OLLAMA ---------------------------------------------------
# No auth needed - LAN access only
# After deploy pull a model:
# docker exec ollama ollama pull gemma:2b
# docker exec ollama ollama pull llama3:8b

# --- ALERTING (v1.1+) -----------------------------------------
# Telegram bot token (from @BotFather) and chat ID
# Get chat_id: msg @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- BACKUP (Restic + B2) -------------------------------------
# B2 bucket credentials (create at: https://www.backblaze.com/b2/)
B2_ACCOUNT_ID=your_b2_account_id
B2_ACCOUNT_KEY=your_b2_application_key
B2_BUCKET=homelab-prod-backup
RESTIC_PASSWORD=change_me_restic_password
RESTIC_REPOSITORY=b2:${B2_BUCKET}:homelab-prod
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6

# --- INFISICAL (v1.2+) ----------------------------------------
# Secret manager - generates these on first run:
# openssl rand -base64 32  # for each
INFISICAL_AUTH_SECRET=change_me_32char_auth_secret
INFISICAL_ENCRYPTION_KEY=change_me_32char_enc_key
INFISICAL_REDIS_PASSWORD=change_me_redis_pass
INFISICAL_POSTGRES_PASSWORD=change_me_pg_pass
INFISICAL_AUTH_ALLOWED_SIGNUP_DOMAINS=yourdomain.com
INFISICAL_AUTH_DISABLE_SIGNUP=true
# After first login, configure:
# - Create project "homelab-prod"
# - Add all .env secrets as Infisical secrets
# - Use Infisical CLI to inject at deploy: infisical run -- docker compose up -d