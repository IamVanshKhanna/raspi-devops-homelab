# =============================================================
# pi4homelab - Environment Variables (optimized stack)
# Copy this file: cp .env.example .env
# Then fill in every value before deploying.
# NEVER commit your .env file - it is in .gitignore
# =============================================================

# --- GENERAL --------------------------------------------------
TZ=Australia/Melbourne
PUID=1000
PGID=1000
DATA_DIR=/mnt/data
BACKUP_DIR=/mnt/backup

# --- DOMAIN ---------------------------------------------------
# If using Tailscale: DOMAIN=hostname.tailnet-name.ts.net
# If using WireGuard/LAN only: DOMAIN=192.168.68.59.nip.io
# If no domain, leave as-is and access via IP:port directly
DOMAIN=yourdomain.local
ACME_EMAIL=your@email.com

# --- TRAEFIK --------------------------------------------------
TRAEFIK_DASHBOARD_USER=admin
# Generate hashed password with:
# echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_PASS=$$2y$$05$$replacethiswithyourhashedpassword

# --- PIHOLE ---------------------------------------------------
PIHOLE_WEBPASSWORD=changeme_pihole
PIHOLE_DNS1=1.1.1.1
PIHOLE_DNS2=8.8.8.8

# --- WIREGUARD ------------------------------------------------
WG_HOST=yourdomain.local
WG_DEFAULT_DNS=192.168.1.50
WG_ALLOWED_IPS=0.0.0.0/0
WG_PEERS=3

# --- VAULTWARDEN ----------------------------------------------
# Generate token with: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=changeme_random_64char

# --- SAMBA ----------------------------------------------------
SAMBA_PASSWORD=changeme

# --- SYNCTHING ------------------------------------------------
# No credentials needed -- set password via Web UI at first login
# Access at http://pi-ip:8384

# --- UPTIME KUMA ----------------------------------------------
# No credentials needed -- set admin account on first visit
# Access at http://pi-ip:3001

# --- CROWDSEC (optional) --------------------------------------
CROWDSEC_DB_PASSWORD=changeme_crowdsec_db

# --- TELEGRAM (TinyBot alerts) --------------------------------
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# --- BACKUP (Restic + B2) -------------------------------------
# B2 bucket credentials (create at: https://www.backblaze.com/b2/)
B2_ACCOUNT_ID=your_b2_account_id
B2_ACCOUNT_KEY=your_b2_application_key
B2_BUCKET=homelab-prod-backup
RESTIC_PASSWORD=changeme_restic
RESTIC_REPOSITORY=b2:${B2_BUCKET}:homelab-prod
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6

# --- AUTHELIA (deployed on Windows) ---------------------------
# Generate with: openssl rand -base64 32
AUTHELIA_JWT_SECRET=changeme_32char_jwt
AUTHELIA_SESSION_SECRET=changeme_32char_session
AUTHELIA_STORAGE_ENCRYPTION_KEY=changeme_32char_storage
AUTHELIA_DB_PASSWORD=changeme_authelia_db
AUTHELIA_REDIS_PASSWORD=changeme_authelia_redis
AUTHELIA_ADMIN_PASSWORD_HASH=changeme_argon2id_hash

# --- NEXTCLOUD (deployed on Windows, optional) ----------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme_strong
NEXTCLOUD_TRUSTED_DOMAINS=cloud.yourdomain.local
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=changeme_db

# --- GRAFANA (deployed on Windows) ----------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana
GF_SERVER_ROOT_URL=https://grafana.yourdomain.local

# --- CLOUDFLARE DNS-01 (optional, only with real domain) ------
# CF_DNS_API_TOKEN=changeme_cf_token
