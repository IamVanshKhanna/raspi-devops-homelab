# =============================================================
# homelab-prod - Environment Variables
# Copy this file: cp .env.example .env
# Then fill in every value before deploying.
# NEVER commit your .env file - it is in .gitignore
# =============================================================

# --- GENERAL --------------------------------------------------
TZ=Australia/Melbourne
PUID=1000
PGID=1000
DATA_DIR=/mnt/data
BACKUP_DIR=/mnt/backup

# --- DOMAIN ---------------------------------------------------
# Your domain or free DuckDNS subdomain
# e.g. myhomelab.duckdns.org
DOMAIN=yourdomain.com
ACME_EMAIL=your@email.com

# --- TRAEFIK --------------------------------------------------
TRAEFIK_DASHBOARD_USER=admin
# Generate hashed password with:
# echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_PASS=$$2y$$05$$replacethiswithyourhashedpassword

# --- NEXTCLOUD ------------------------------------------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme_strong
NEXTCLOUD_TRUSTED_DOMAINS=cloud.yourdomain.com

# --- MARIADB (Nextcloud database) -----------------------------
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=changeme_db

# --- VAULTWARDEN ----------------------------------------------
# Generate token with: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=changeme_random_64char

# --- GRAFANA --------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana
GF_SERVER_ROOT_URL=https://grafana.yourdomain.com

# --- PIHOLE ---------------------------------------------------
PIHOLE_WEBPASSWORD=changeme_pihole
PIHOLE_DNS1=1.1.1.1
PIHOLE_DNS2=8.8.8.8

# --- WIREGUARD ------------------------------------------------
WG_HOST=yourdomain.com
WG_DEFAULT_DNS=192.168.1.50
WG_ALLOWED_IPS=0.0.0.0/0
WG_PEERS=3

# --- ALERTING (v1.1+) -----------------------------------------
# Telegram bot token (from @BotFather) and chat ID
# Get chat_id: msg @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- BACKUP (Restic + B2) -------------------------------------
# B2 bucket credentials (create at: https://www.backblaze.com/b2/)
B2_ACCOUNT_ID=your_b2_account_id
B2_ACCOUNT_KEY=your_b2_application_key
B2_BUCKET=homelab-prod-backup
RESTIC_PASSWORD=changeme_restic
RESTIC_REPOSITORY=b2:${B2_BUCKET}:homelab-prod
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6

# --- TINYBOT (Telegram Bot) -----------------------------------
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# --- INFISICAL (v1.2+) ----------------------------------------
INFISICAL_AUTH_SECRET=changeme_32char_auth
INFISICAL_ENCRYPTION_KEY=changeme_32char_enc
INFISICAL_REDIS_PASSWORD=changeme_redis
INFISICAL_POSTGRES_PASSWORD=changeme_pg
INFISICAL_AUTH_ALLOWED_SIGNUP_DOMAINS=yourdomain.com
INFISICAL_AUTH_DISABLE_SIGNUP=true

# --- AUTHELIA (v1.4+) -----------------------------------------
# Generate with: openssl rand -base64 32
AUTHELIA_JWT_SECRET=changeme_32char_jwt
AUTHELIA_SESSION_SECRET=changeme_32char_session
AUTHELIA_STORAGE_ENCRYPTION_KEY=changeme_32char_storage
AUTHELIA_DB_PASSWORD=changeme_authelia_db
AUTHELIA_REDIS_PASSWORD=changeme_authelia_redis
# Generate with: docker run --rm authelia/authelia:4.38.0 authelia crypto hash generate argon2id --password 'your-password'
# Paste the output here:
AUTHELIA_ADMIN_PASSWORD_HASH=changeme_argon2id_hash

# --- CLOUDFLARE DNS-01 (v1.4+) --------------------------------
# For DNS-01 challenge (closes port 80)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone > DNS > Edit
CF_DNS_API_TOKEN=changeme_cf_token
# Uncomment to enable DNS-01 (closes port 80):
# TRAEFIK_ACME_DNS_CHALLENGE=true

# --- CROWDSEC (v1.4+) -----------------------------------------
# CrowdSec for intrusion detection
# Optional: CROWDSEC_API_KEY for cloud console
# CROWDSEC_API_KEY=changeme_crowdsec_key